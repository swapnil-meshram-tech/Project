# ============================================
# .gitignore
# Prevent committing sensitive files to git
# ============================================

# ============================================
# Environment Files (NEVER commit .env files with secrets)
# ============================================
.env.development
.env.staging
.env.production
.env.test
.env.local
.env.*.local

# ============================================
# Dependencies
# ============================================
node_modules/
npm-debug.log*
yarn-error.log*

# ============================================
# Build & Dist
# ============================================
dist/
build/
*.tgz

# ============================================
# IDE & Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/

# ============================================
# Cache
# ============================================
.cache/
.eslintcache

# ============================================
# OS
# ============================================
Thumbs.db
.DS_Store

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp